{
      "buildCommand": "",
      "outputDirectory": "public",
      "functions": {
              "api/*.js": {
                        "runtime": "@vercel/node@3"
              }
      },
      "rewrites": [
              { "source": "/api/:path*", "destination": "/api/:path*" },
              { "source": "/(.*)", "destination": "/index.html" }
      ],
      "headers": [
              {
                        "source": "/sw.js",
                        "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
              }
      ]
}
